# Gmail address you want to SEND FROM and RECEIVE messages at
GMAIL_USER=abdulnasrin2007@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Steps to create one:
# 1. Go to Google Account → Security
# 2. Enable 2-Step Verification
# 3. Go to Security → App passwords
# 4. Create app password for "Mail" → copy the 16-char password
GMAIL_PASS=

# Your deployed frontend URL (for CORS)
# Example: https://abdulnasrin.vercel.app
FRONTEND_URL=https://your-portfolio-url.vercel.app

# Port (Render sets this automatically)
PORT=3001
